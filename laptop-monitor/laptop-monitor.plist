<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.laptop-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>__INSTALL_DIR__/venv/bin/python</string>
        <string>__INSTALL_DIR__/monitor.py</string>
        <string>--run</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__INSTALL_DIR__/monitor.log</string>

    <key>StandardErrorPath</key>
    <string>__INSTALL_DIR__/monitor.err</string>
</dict>
</plist>
